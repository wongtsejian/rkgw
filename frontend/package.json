{
  "name": "web-ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "cd ../e2e-tests && npx playwright test --project=ui-public --project=ui-authenticated --project=ui-admin",
    "test:e2e:headed": "cd ../e2e-tests && npx playwright test --project=ui-public --project=ui-authenticated --project=ui-admin --headed",
    "test:e2e:ui": "cd ../e2e-tests && npx playwright test --project=ui-public --project=ui-authenticated --project=ui-admin --ui",
    "test:e2e:setup": "cd ../e2e-tests && npx playwright codegen --ignore-https-errors --save-storage=.auth/session.json https://localhost/_ui/",
    "test:e2e:report": "cd ../e2e-tests && npx playwright show-report"
  },
  "dependencies": {
    "@datadog/browser-rum": "^6.28.1",
    "@datadog/browser-rum-react": "^6.28.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.52.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0"
  }
}
