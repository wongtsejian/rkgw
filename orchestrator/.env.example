# Required
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GH_TOKEN=your-github-pat-here
ORCHESTRATOR_API_KEY=your-orchestrator-bearer-token-here
REPO_URL=git@github.com:if414013/harbangan.git

# Optional
REPO_BRANCH=main
ORCHESTRATOR_PORT=3000
MAX_CONCURRENT_TASKS=3
DEFAULT_BUDGET_USD=10
DAILY_BUDGET_LIMIT_USD=100
MONTHLY_BUDGET_LIMIT_USD=1000
DEFAULT_MODEL=claude-sonnet-4-6

# Task Store Backend (sqlite or github)
TASK_STORE_BACKEND=sqlite
GH_PROJECT_NUMBER=3
GH_OWNER=if414013
GH_REPO=harbangan

# Slack (optional — both tokens required for interactive workflows)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
ASK_USER_TIMEOUT_MS=1800000

# GitHub Webhooks (optional — enables auto PR review on push)
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ChromaDB Knowledge Base (optional)
CHROMA_URL=http://chromadb:8000

# Workspace
WORKSPACE_DIR=/workspace
DATA_DIR=/data
