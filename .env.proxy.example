# Proxy-only mode environment variables
# Copy to .env.proxy and set PROXY_API_KEY
#
# Usage: docker compose -f docker-compose.gateway.yml --env-file .env.proxy up -d

# Required: Deployment mode
GATEWAY_MODE=proxy

# Required: API key for client authentication
PROXY_API_KEY=your-api-key-here

# ── Kiro (default provider, uses device code flow if no token set) ───
# KIRO_REGION=us-east-1
# KIRO_SSO_REGION=
# KIRO_SSO_URL=

# ── Anthropic (enables claude-* models) ──────────────────────────────
# ANTHROPIC_API_KEY=

# ── OpenAI (enables gpt-* models) ───────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── GitHub Copilot (device flow runs if token not set) ───────────────
# COPILOT_TOKEN=
# COPILOT_BASE_URL=https://api.githubcopilot.com

# ── Custom OpenAI-compatible provider (e.g. Ollama, vLLM) ───────────
# CUSTOM_PROVIDER_URL=http://localhost:11434/v1
# CUSTOM_PROVIDER_KEY=
# CUSTOM_PROVIDER_MODELS=llama3,codellama,deepseek-r1

# ── General ──────────────────────────────────────────────────────────
# BIND_ADDRESS=127.0.0.1
# SERVER_PORT=8000
# LOG_LEVEL=info
# DEBUG_MODE=off
