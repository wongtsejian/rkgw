# Kiro Gateway — Bootstrap Configuration
# Copy this file to .env and adjust as needed.
#
# Only bootstrap settings belong here. Everything else (API key, region,
# timeouts, debug mode, HTTP client tuning, etc.) is managed via the
# Web UI at /_ui/ and persisted in PostgreSQL.

# Server bind address and port
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# PostgreSQL connection string (required)
# For Docker deployment, this is set automatically in docker-compose.yml
# DATABASE_URL=postgres://kiro:kiro_secret@localhost:5432/kiro_gateway

# TLS — optional custom certificate (self-signed generated when not set)
# TLS_CERT=/path/to/cert.pem
# TLS_KEY=/path/to/key.pem

# Enable the web UI dashboard at /_ui/ (default: true)
# WEB_UI=true
