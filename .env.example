# Kiro Gateway — Docker Compose Configuration
# Copy this file to .env and adjust as needed.
#
# Runtime settings (API key, region, timeouts, etc.) are managed
# via the Web UI at /_ui/ and persisted in PostgreSQL.

# PostgreSQL password
POSTGRES_PASSWORD=kiro_secret

# ── Production / Kubernetes (not used in local dev) ──────────────
# The Datadog agent runs at the Kubernetes cluster level, not as a
# local Docker sidecar. Set these vars in your K8s deployment manifests
# or Helm values — they are ignored by docker-compose.yml.
#
# DD_API_KEY=
# DD_SITE=datadoghq.com
# DD_ENV=production
# DD_AGENT_HOST=datadog-agent
# DD_AGENT_PORT=8126
# DD_SERVICE=harbangan-backend
# DD_VERSION=1.0.8
#
# Datadog RUM (frontend browser monitoring, build-time)
# VITE_DD_CLIENT_TOKEN=
# VITE_DD_APPLICATION_ID=
# VITE_DD_ENV=production
# VITE_DD_SERVICE=harbangan-frontend
# VITE_DD_SITE=datadoghq.com

# Initial admin account (required for first-run setup)
# The backend creates this admin user on first startup.
# Google SSO is configured via the Admin UI after login.
# Also used by E2E tests (e2e-tests/) for automated login via password + TOTP.
# INITIAL_ADMIN_EMAIL=admin@example.com
# INITIAL_ADMIN_PASSWORD=changeme
# INITIAL_ADMIN_TOTP_SECRET=your-base32-totp-secret-here

# Provider OAuth client IDs (optional — now DB-configurable via Admin UI)
# These env vars serve as bootstrap defaults. Once set in the Admin UI,
# the database value takes precedence.
# Config encryption key (optional)
# Base64-encoded 32-byte key for encrypting sensitive config values in the DB.
# Generate with: openssl rand -base64 32
# CONFIG_ENCRYPTION_KEY=

# ── Proxy-only mode (docker-compose.gateway.yml) ─────────────────
# Single-container deployment without PostgreSQL or web UI.
# Set GATEWAY_MODE=proxy and PROXY_API_KEY to enable.
# See .env.proxy.example for the full template.
# GATEWAY_MODE=proxy
# PROXY_API_KEY=your-api-key-here

# ── Multi-Provider Proxy Mode ────────────────────────────────────────
# These variables are only used in proxy-only mode (GATEWAY_MODE=proxy).
# Set credentials for any providers you want to route through.
# At least one provider (Kiro or any below) must be configured.
#
# Anthropic (enables claude-* models)
# ANTHROPIC_API_KEY=
#
# OpenAI (enables gpt-* models)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# GitHub Copilot (enables copilot models, or use device flow)
# COPILOT_TOKEN=
# COPILOT_BASE_URL=https://api.githubcopilot.com
#
# Custom OpenAI-compatible provider (e.g. Ollama, vLLM, LM Studio)
# CUSTOM_PROVIDER_URL=http://localhost:11434/v1
# CUSTOM_PROVIDER_KEY=
# CUSTOM_PROVIDER_MODELS=llama3,codellama,deepseek-r1
